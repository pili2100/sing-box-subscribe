  "dns": {
    "servers": [
      {
        "type": "h3",
        "tag": "proxyDns",
        "detour": "proxy",
        "domain_resolver": "localDns",
        "server": "cloudflare-dns.com",
        "server_port": 443,
        "tls": {
          "server_name": "cloudflare-dns.com"
        },
        "path": "/dns-query"
      },
      {
        "type": "h3",
        "tag": "localDns",
        "server": "223.6.6.6"
      },
      {
        "type": "fakeip",
        "tag": "dns_fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "rule_set": "geosite-category-ads-all",
        "action": "reject"
      },
      {
        "clash_mode": "direct",
        "server": "localDns"
      },
      {
        "clash_mode": "global",
        "server": "dns_fakeip"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "query_type": [
              "A",
              "CNAME"
            ],
            "rule_set": [
              "geosite-cn",
              "geosite-geolocation-cn"
            ]
          }
        ],
        "server": "localDns",
        "disable_cache": true
      },
      {
        "rule_set": [
          "geosite-geolocation-!cn"
        ],
        "invert": true,
        "action": "evaluate",
        "server": "proxyDns",
        "client_subnet": "104.174.125.138"
      },
      {
        "match_response": true,
        "rule_set": "geoip-cn",
        "server": "localDns",
        "disable_cache": true
      },
      {
        "match_response": true,
        "query_type": [
          "AAAA"
        ],
        "server": "dns_fakeip",
        "rewrite_ttl": 30
      },
      {
        "rule_set": [
          "geosite-geolocation-!cn"
        ],
        "invert": true,
        "action": "respond"
      }
    ],
    "final": "proxyDns",
    "strategy": "ipv4_only",
    "cache_capacity": 2048
  },
