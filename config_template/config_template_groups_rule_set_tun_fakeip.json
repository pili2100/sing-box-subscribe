  "dns": {
    "servers": [
      {
        "tag": "proxyDns",
        "address": "https://dns.cloudflare.com/dns-query",
        "strategy": "ipv4_only",
        "address_resolver": "localDns",
        "client_subnet": "223.6.6.6",
        "detour": "proxy"
      },
      {
        "tag": "localDns",
        "address": "h3://223.6.6.6/dns-query#h3=true",
        "strategy": "prefer_ipv6",
        "detour": "direct"
      },
      {
        "tag": "nblock",
        "address": "rcode://refused"
      },
      {
        "tag": "dns_fakeip",
        "address": "fakeip",
        "strategy": "prefer_ipv6"
      }
    ],
    "rules": [
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": "geosite-category-ads-all"
          },
          {
            "domain_suffix": [
              ".mcdn.bilivideo.cn",
              ".szbdyd.com"
            ],
            "domain_regex": [
              "cn-[a-zA-Z0-9-]+\\.bilivideo\\.com",
              "[a-zA-Z0-9-]+-pcdn-[a-zA-Z0-9-]+\\.biliapi\\.net"
            ]
          }
        ],
        "server": "nblock",
        "disable_cache": true
      },
      {
        "outbound": "any",
        "server": "localDns",
        "disable_cache": true
      },
      {
        "clash_mode": "direct",
        "server": "localDns"
      },
      {
        "clash_mode": "global",
        "server": "dns_fakeip"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geosite-geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": "geoip-cn",
            "invert": true
          },
          {
            "rule_set": "geosite-geolocation-cn",
            "invert": true
          },
          {
            "rule_set": "geosite-cn",
            "invert": true
          }
        ],
        "server": "proxyDns",
        "disable_cache": true
      },
      {
        "query_type": [
          "A",
          "CNAME"    
        ],
        "rule_set": [
          "geosite-cn",
          "geosite-geolocation-cn"
        ],
        "server": "localDns",
        "disable_cache": true
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "query_type": [
              "A",
              "AAAA"
            ]
          }
        ],
        "server": "dns_fakeip",
        "rewrite_ttl": 30
      }
    ],
    "independent_cache": true,
    "final": "proxyDns",
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    }
